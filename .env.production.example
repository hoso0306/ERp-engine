# Template biến môi trường PRODUCTION — copy thành .env.production trên VPS
# và điền giá trị thật. KHÔNG commit file .env.production (đã ignore trong
# .gitignore), chỉ file .example này được commit.
#
# Dùng: docker compose -f docker-compose.prod.yml --env-file .env.production up -d --build

# --- Database ---
DB_USER=erp
# Đổi mật khẩu thật, không dùng giá trị mẫu này.
DB_PASSWORD=doi-mat-khau-that-o-day
DB_NAME=erp
DATABASE_URL=postgresql://erp:doi-mat-khau-that-o-day@postgres:5432/erp

# --- Auth ---
# Generate bằng: openssl rand -base64 32
JWT_SECRET=doi-jwt-secret-that-o-day

# --- Web build (build-time — đổi domain phải build lại image, xem apps/web/Dockerfile) ---
# Domain gốc, KHÔNG kèm /api (code FE tự thêm /api, xem apps/web/src/lib/api.ts).
NEXT_PUBLIC_API_URL=https://your-domain.example

# --- Bootstrap Owner (chỉ dùng khi chạy `docker compose exec api npx prisma db seed` lần đầu) ---
BOOTSTRAP_OWNER_EMAIL=owner@your-domain.example
BOOTSTRAP_OWNER_NAME=Owner
