generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ──────────────────────────────────────
// Enum
// ──────────────────────────────────────

enum Priority {
  LOW
  MEDIUM
  HIGH
}

enum CustomerStatus {
  ACTIVE
  INACTIVE
}

enum ProductStatus {
  DRAFT
  ACTIVE
  INACTIVE
}

enum ParameterType {
  NUMBER
  TEXT
  ENUM
  BOOLEAN
}

enum VersionStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum RoundType {
  NONE
  CEIL
  FLOOR
  ROUND
}

enum PricingRuleType {
  MIN_AREA
  MIN_DIMENSION
  MIN_VALUE
  BILLABLE_STEP
  ROUND
  CUSTOM
}

enum ValidationSeverity {
  WARN
  BLOCK
}

enum QuotationStatus {
  DRAFT
  SENT
  APPROVED
  CANCELLED
}

enum QuotationTimelineAction {
  QUOTATION_CREATED
  QUOTATION_SENT
  QUOTATION_APPROVED
  QUOTATION_CANCELLED
  QUOTATION_MANUAL_OVERRIDE
}

enum SalesOrderStatus {
  IN_PRODUCTION
  PRODUCTION_COMPLETED
  SHIPPED
  DELIVERED
  CANCELLED
}

enum ProductionOrderStatus {
  PENDING
  IN_PRODUCTION
  PRODUCTION_COMPLETED
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  PARTIALLY_PAID
  PAID
}

enum SalesOrderTimelineActorType {
  SYSTEM
  USER
}

enum SalesOrderTimelineAction {
  SALES_ORDER_CREATED
  PRODUCTION_ORDERS_GENERATED
  PRODUCTION_COMPLETED
  SHIPPED
  DELIVERED
  PAYMENT_STATUS_CHANGED
  MANUAL_OVERRIDE
  // Sửa địa chỉ giao hàng của đơn (Sprint 04, 009-in-phieu-san-xuat.md) —
  // không phải Manual Override (không đổi Status, không bắt buộc lý do).
  DELIVERY_ADDRESS_UPDATED
  // Sửa thông tin nhà xe/vận chuyển (Sprint 04, 009-in-phieu-san-xuat.md) —
  // cùng cơ chế với DELIVERY_ADDRESS_UPDATED nhưng là 1 nhóm dữ liệu khác
  // (nhà xe chở hàng, không phải người/nơi nhận hàng).
  CARRIER_INFO_UPDATED
  CANCELLED
}

// Enum riêng cho Production, không tái sử dụng SalesOrderTimelineActorType —
// xem knowledge/modules/production.md mục ActorType.
enum ProductionOrderTimelineActorType {
  SYSTEM
  USER
}

enum ProductionOrderTimelineAction {
  PRODUCTION_ORDER_CREATED
  STARTED
  COMPLETED
  CANCELLED
  // In phiếu A5 (Sprint 04, 009-in-phieu-san-xuat.md) — không đổi Status,
  // chỉ ghi vết đã in lúc nào, ai in.
  PRINTED
}

enum WarehouseDirection {
  IN
  OUT
}

enum WarehouseTransactionType {
  MATERIAL_RECEIPT
  MATERIAL_ISSUE
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
}

enum SettingValueType {
  BOOLEAN
  NUMBER
  STRING
  TEXT
}

enum ReturnReason {
  WRONG_SIZE
  WRONG_COLOR
  WRONG_MODEL
  PRODUCTION_DEFECT
  INSTALLATION_DEFECT
  CUSTOMER_CHANGED_MIND
  OTHER
}

// Trạng thái xử lý Return — một chiều PROCESSING → COMPLETED qua Action
// POST /returns/:id/complete (xem return.md mục "Trạng thái Return").
enum ReturnStatus {
  PROCESSING
  COMPLETED
}

enum RecoveryInventoryStatus {
  AVAILABLE
  USED
  DISPOSED
}

enum PermissionAuditAction {
  GRANT
  REVOKE
  ROLE_CREATED
  ROLE_DISABLED
  USER_CREATED
  USER_DISABLED
  USER_ROLE_CHANGED
}

// ──────────────────────────────────────
// System
// ──────────────────────────────────────

model User {
  id                 String    @id @default(cuid())
  email              String    @unique
  // Đăng nhập được bằng email hoặc SĐT (xem AuthService.login()) — tuỳ chọn,
  // User cũ không có SĐT vẫn đăng nhập bằng email bình thường.
  phone              String?   @unique
  name               String?
  // bcrypt hash — không bao giờ lưu/trả về plaintext (xem authentication.md).
  passwordHash       String    @map("password_hash")
  isActive           Boolean   @default(true) @map("is_active")
  lastLoginAt        DateTime? @map("last_login_at")
  lastLoginIp        String?   @map("last_login_ip")
  // Bật khi setTemporaryPassword() chạy, tắt khi tự đổi mật khẩu thành công.
  // Field theo từng User — khác với Settings.Security.forceChangePasswordOnFirstLogin
  // (công tắc chung toàn hệ thống, chỉ quyết định giá trị ban đầu của field này).
  mustChangePassword Boolean   @default(false) @map("must_change_password")
  // Chống dò mật khẩu (chốt 20/07/2026): sai 5 lần liên tiếp khoá 5 phút, sai
  // đủ 10 lần khoá 30 phút — đếm dồn, chỉ reset về 0 khi đăng nhập đúng (xem
  // AuthService.login()). Không tính khi tài khoản đang bị khoá (không kiểm
  // tra mật khẩu lúc đó nên không tăng thêm).
  failedLoginAttempts Int       @default(0) @map("failed_login_attempts")
  lockedUntil         DateTime? @map("locked_until")
  // Bắt buộc, gán khi tạo User (013-permission.md) — Authentication chỉ đọc để
  // đưa vào payload JWT, không sở hữu field này (xem permission.md).
  roleId             String    @map("role_id")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  role Role @relation(fields: [roleId], references: [id])

  saleCustomers    Customer[]   @relation("CustomerSale")
  createdCustomers Customer[]   @relation("CustomerCreatedBy")
  updatedCustomers Customer[]   @relation("CustomerUpdatedBy")
  ownedSalesOrders SalesOrder[]

  // Sprint 04 (005-nguoi-thuc-hien-lich-su-hoat-dong.md) — actor snapshot cho audit trail.
  quotationTimelines       QuotationTimeline[]
  salesOrderTimelines      SalesOrderTimeline[]
  productionOrderTimelines ProductionOrderTimeline[]
  completedReturns         Return[]
  createdMaterialReceipts  MaterialReceipt[]

  @@index([roleId])
  @@map("users")
}

// ──────────────────────────────────────
// Permission (Authorization)
// ──────────────────────────────────────

model Role {
  id        String   @id @default(cuid())
  // Bất biến sau khi tạo — dùng để so sánh cứng trong Business Rule (vd
  // "Owner cuối cùng" so sánh role.code == 'OWNER', không so sánh name).
  code      String   @unique
  name      String
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users           User[]
  rolePermissions RolePermission[]
  audits          PermissionAudit[]

  @@map("roles")
}

model Permission {
  id        String   @id @default(cuid())
  resource  String
  action    String
  // Derived Data được phép lưu — lý do Hiệu năng đọc, PermissionGuard chạy
  // trên gần như mọi request (xem permission.md mục "Permission").
  key       String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  rolePermissions RolePermission[]
  audits          PermissionAudit[]

  @@map("permissions")
}

model RolePermission {
  id           String   @id @default(cuid())
  roleId       String   @map("role_id")
  permissionId String   @map("permission_id")
  createdAt    DateTime @default(now()) @map("created_at")

  role       Role       @relation(fields: [roleId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])

  @@unique([roleId, permissionId])
  @@index([permissionId])
  @@map("role_permissions")
}

// Append-only — không có Update/Delete (xem permission.md mục "Audit").
model PermissionAudit {
  id           String                @id @default(cuid())
  roleId       String                @map("role_id")
  permissionId String?               @map("permission_id")
  // Target user cho USER_CREATED/USER_DISABLED/USER_ROLE_CHANGED — không có
  // trong bảng field gốc ở Task 00 nhưng bắt buộc phải có để biết audit đang
  // nói về User nào (roleId một mình không đủ định danh). Redundant reference
  // (không @relation), cùng convention các field điều hướng khác trong schema.
  userId       String?               @map("user_id")
  action       PermissionAuditAction
  // changedBy — userId thực hiện thay đổi. Scalar, không @relation, cùng
  // convention với SalesOrderTimeline.createdBy/QuotationTimeline.createdBy.
  changedBy    String?               @map("changed_by")
  // Chỉ lưu phần thay đổi (delta), không snapshot toàn bộ object.
  payload      Json?
  createdAt    DateTime              @default(now()) @map("created_at")

  role       Role        @relation(fields: [roleId], references: [id])
  permission Permission? @relation(fields: [permissionId], references: [id])

  @@index([roleId])
  @@index([userId])
  @@index([createdAt])
  @@map("permission_audits")
}

model RunningNumber {
  id            String   @id @default(cuid())
  type          String   @unique
  prefix        String
  lastNumber    Int      @default(0) @map("last_number")
  paddingLength Int      @default(6) @map("padding_length")
  // Chỉ ẩn/hiện loại chứng từ khỏi menu — không chặn tạo chứng từ (xem setting.md).
  enabled       Boolean  @default(true)
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("running_numbers")
}

// ──────────────────────────────────────
// Master Data
// ──────────────────────────────────────

model CustomerGroup {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  customers Customer[]

  @@map("customer_groups")
}

// Chiết khấu theo Khách hàng × Sản phẩm (Sprint 04, chốt 16/07/2026) — THAY THẾ
// HOÀN TOÀN CustomerGroup.discountPercent ("CK nhóm"). Master Data, không
// versioned — khi thêm/sửa dòng báo giá, hệ thống snapshot % này vào
// QuotationItem.discountPercent (xem quotation.md mục "Discount Engine").
model CustomerProductDiscount {
  id              String   @id @default(cuid())
  customerId      String   @map("customer_id")
  productId       String   @map("product_id")
  discountPercent Decimal  @map("discount_percent") @db.Decimal(5, 2)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  customer Customer @relation(fields: [customerId], references: [id])
  product  Product  @relation(fields: [productId], references: [id])

  @@unique([customerId, productId])
  @@map("customer_product_discounts")
}

model DeliveryRoute {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  customers Customer[]

  @@map("delivery_routes")
}

// ──────────────────────────────────────
// Production Center
// ──────────────────────────────────────

model ProductionCenter {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  products  Product[]
  materials MaterialProductionCenter[]

  @@index([isActive])
  @@map("production_centers")
}

// Vật tư thuộc nhiều xưởng (chốt 08/07/2026) — hiện CHỈ dùng để lọc danh sách
// vật tư, không ảnh hưởng nghiệp vụ xuất kho/BOM. Join table explicit theo
// convention RolePermission.
model MaterialProductionCenter {
  id                 String   @id @default(cuid())
  materialId         String   @map("material_id")
  productionCenterId String   @map("production_center_id")
  createdAt          DateTime @default(now()) @map("created_at")

  material         Material         @relation(fields: [materialId], references: [id], onDelete: Cascade)
  productionCenter ProductionCenter @relation(fields: [productionCenterId], references: [id])

  @@unique([materialId, productionCenterId])
  @@index([productionCenterId])
  @@map("material_production_centers")
}

// ──────────────────────────────────────
// Unit & Product Type
// ──────────────────────────────────────

model Unit {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  materials Material[]
  products  Product[]

  @@map("units")
}

model ProductType {
  id        String   @id @default(cuid())
  name      String   @unique
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  products Product[]

  @@map("product_types")
}

// ──────────────────────────────────────
// Material
// ──────────────────────────────────────

model Material {
  id           String   @id @default(cuid())
  code         String   @unique
  name         String
  unitId       String   @map("unit_id")
  isActive     Boolean  @default(true) @map("is_active")
  note         String?
  // Giá bán lẻ (chốt 08/07/2026): dùng khi bán lẻ/tính giá bán. Giá VỐN vẫn
  // dùng giá nhập (MaterialPrice) — không đụng Pricing/BOM Engine. Source
  // Data nhập tay, nullable (vật tư không bán lẻ để trống).
  retailPrice  Decimal? @map("retail_price") @db.Decimal(15, 0)
  currentStock Decimal  @default(0) @map("current_stock") @db.Decimal(15, 4)
  minimumStock Decimal? @map("minimum_stock") @db.Decimal(15, 4)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  unit              Unit                       @relation(fields: [unitId], references: [id])
  prices            MaterialPrice[]
  requirementItems  MaterialRequirementItem[]
  receiptItems      MaterialReceiptItem[]
  transactions      WarehouseTransaction[]
  productionCenters MaterialProductionCenter[]

  @@index([isActive])
  @@map("materials")
}

model MaterialPrice {
  id            String    @id @default(cuid())
  materialId    String    @map("material_id")
  supplierId    String?   @map("supplier_id")
  supplierName  String?   @map("supplier_name")
  price         Decimal   @db.Decimal(15, 2)
  effectiveFrom DateTime  @map("effective_from")
  effectiveTo   DateTime? @map("effective_to")
  isDefault     Boolean   @default(false) @map("is_default")
  note          String?
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  material Material @relation(fields: [materialId], references: [id])

  @@index([materialId])
  @@index([materialId, isDefault])
  @@index([materialId, effectiveFrom])
  @@map("material_prices")
}

// ──────────────────────────────────────
// Product
// ──────────────────────────────────────

model Product {
  id                 String        @id @default(cuid())
  code               String        @unique
  name               String
  productTypeId      String        @map("product_type_id")
  unitId             String        @map("unit_id")
  productionCenterId String        @map("production_center_id")
  status             ProductStatus @default(DRAFT)
  description        String?
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt @map("updated_at")
  deletedAt          DateTime?     @map("deleted_at")

  productType         ProductType               @relation(fields: [productTypeId], references: [id])
  unit                Unit                      @relation(fields: [unitId], references: [id])
  productionCenter    ProductionCenter          @relation(fields: [productionCenterId], references: [id])
  parameters          ProductParameter[]
  pricingRule         PricingRule?
  materialRequirement MaterialRequirement?
  quotationItems      QuotationItem[]
  validationRules     ValidationRule[]
  derivedParameters   DerivedParameter[]
  customerDiscounts   CustomerProductDiscount[]

  @@index([productTypeId])
  @@index([productionCenterId])
  @@index([status])
  @@index([deletedAt])
  @@map("products")
}

model ProductParameter {
  id             String        @id @default(cuid())
  productId      String        @map("product_id")
  name           String
  label          String
  type           ParameterType
  unit           String?
  defaultValue   String?       @map("default_value")
  isRequired     Boolean       @default(false) @map("is_required")
  minValue       Decimal?      @map("min_value") @db.Decimal(15, 4)
  maxValue       Decimal?      @map("max_value") @db.Decimal(15, 4)
  step           Decimal?      @db.Decimal(15, 4)
  usedInPricing  Boolean       @default(true) @map("used_in_pricing")
  usedInMaterial Boolean       @default(true) @map("used_in_material")
  displayOrder   Int           @default(0) @map("display_order")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  product Product                  @relation(fields: [productId], references: [id])
  options ProductParameterOption[]

  @@unique([productId, name])
  @@index([productId, displayOrder])
  @@map("product_parameters")
}

model ProductParameterOption {
  id           String   @id @default(cuid())
  parameterId  String   @map("parameter_id")
  value        String
  label        String?
  displayOrder Int      @default(0) @map("display_order")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  parameter ProductParameter @relation(fields: [parameterId], references: [id], onDelete: Cascade)

  @@index([parameterId, displayOrder])
  @@map("product_parameter_options")
}

// ──────────────────────────────────────
// Pricing Rule
// ──────────────────────────────────────

model PricingRule {
  id        String   @id @default(cuid())
  productId String   @unique @map("product_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  product  Product              @relation(fields: [productId], references: [id])
  versions PricingRuleVersion[]

  @@map("pricing_rules")
}

model PricingRuleVersion {
  id              String        @id @default(cuid())
  pricingRuleId   String        @map("pricing_rule_id")
  versionNumber   Int           @map("version_number")
  name            String?
  expression      String?
  // Công thức phụ phí cộng SAU khi Discount Engine (Quotation module) đã áp
  // discountPercent — KHÔNG gộp vào expression/systemPrice, tránh bị chiết
  // khấu ăn vào (vd rèm cầu vồng: máng nhôm +20.000đ/m² dù khách được CK 60%).
  // Optional — trống = không có phụ phí. Cùng ngôn ngữ Expression, dùng chung
  // biến với expression chính (tham số sản phẩm + unitPrice nếu có matrix).
  surchargeExpression String? @map("surcharge_expression")
  priceRoundType  RoundType     @default(NONE) @map("price_round_type")
  priceRoundValue Decimal?      @map("price_round_value") @db.Decimal(15, 0)
  // Thuế suất VAT (%) — snapshot xuống QuotationItem.vatRate khi tính giá,
  // tính SAU Discount Engine (Quotation module), không gộp vào systemPrice.
  vatRate         Decimal       @default(0) @map("vat_rate") @db.Decimal(5, 2)
  status          VersionStatus @default(DRAFT)
  note            String?
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  pricingRule PricingRule       @relation(fields: [pricingRuleId], references: [id])
  items       PricingRuleItem[]
  matrixRows  PriceMatrixRow[]

  @@unique([pricingRuleId, versionNumber])
  @@index([pricingRuleId, status])
  @@map("pricing_rule_versions")
}

// Ma trận đơn giá theo tổ hợp Configuration (Sprint 03 Task 04).
// Version chung một aggregate với PricingRuleVersion — một lần activate là
// một bảng giá hoàn chỉnh (matrix + rules + rounding), một ID để snapshot.
model PriceMatrixRow {
  id                   String   @id @default(cuid())
  pricingRuleVersionId String   @map("pricing_rule_version_id")
  // Tổ hợp config: map tên parameter → value, ví dụ {"maukhung":"cafe","socanh":"2"}
  dimensions           Json
  // Khóa chuẩn hóa từ dimensions (sort theo tên, "maukhung=cafe|socanh=2") —
  // Json không đánh unique trực tiếp được nên unique qua khóa này.
  configKey            String   @map("config_key")
  unitPrice            Decimal  @map("unit_price") @db.Decimal(15, 0)
  displayOrder         Int      @default(0) @map("display_order")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  pricingRuleVersion PricingRuleVersion @relation(fields: [pricingRuleVersionId], references: [id], onDelete: Cascade)

  @@unique([pricingRuleVersionId, configKey])
  @@index([pricingRuleVersionId])
  @@map("price_matrix_rows")
}

model PricingRuleItem {
  id                   String          @id @default(cuid())
  pricingRuleVersionId String          @map("pricing_rule_version_id")
  ruleType             PricingRuleType @map("rule_type")
  targetParameter      String?         @map("target_parameter")
  value                Decimal         @db.Decimal(15, 4)
  // Rule Language chung (Sprint 03): expression boolean, null = luôn áp dụng.
  // Ví dụ: socanh == 2 && maukhung == "cafe"
  condition            String?
  // BILLABLE_STEP (bậc thang): targetParameter trong [rangeFrom, rangeTo) → tính bằng billValue.
  rangeFrom            Decimal?        @map("range_from") @db.Decimal(15, 4)
  rangeTo              Decimal?        @map("range_to") @db.Decimal(15, 4)
  billValue            Decimal?        @map("bill_value") @db.Decimal(15, 4)
  displayOrder         Int             @default(0) @map("display_order")
  description          String?
  createdAt            DateTime        @default(now()) @map("created_at")
  updatedAt            DateTime        @updatedAt @map("updated_at")

  pricingRuleVersion PricingRuleVersion @relation(fields: [pricingRuleVersionId], references: [id], onDelete: Cascade)

  @@index([pricingRuleVersionId])
  @@map("pricing_rule_items")
}

// ──────────────────────────────────────
// Material Requirement
// ──────────────────────────────────────

model MaterialRequirement {
  id        String   @id @default(cuid())
  productId String   @unique @map("product_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  product  Product                      @relation(fields: [productId], references: [id])
  versions MaterialRequirementVersion[]

  @@map("material_requirements")
}

model MaterialRequirementVersion {
  id                    String        @id @default(cuid())
  materialRequirementId String        @map("material_requirement_id")
  versionNumber         Int           @map("version_number")
  name                  String?
  status                VersionStatus @default(DRAFT)
  note                  String?
  createdAt             DateTime      @default(now()) @map("created_at")
  updatedAt             DateTime      @updatedAt @map("updated_at")

  materialRequirement MaterialRequirement       @relation(fields: [materialRequirementId], references: [id])
  items               MaterialRequirementItem[]

  @@unique([materialRequirementId, versionNumber])
  @@index([materialRequirementId, status])
  @@map("material_requirement_versions")
}

model MaterialRequirementItem {
  id                           String    @id @default(cuid())
  materialRequirementVersionId String    @map("material_requirement_version_id")
  materialId                   String    @map("material_id")
  expression                   String
  // Chọn vật tư theo Configuration (Sprint 03): expression boolean, null = dòng
  // luôn được dùng. Ví dụ: maukhung == "cafe" → dòng AL30-CAFE.
  condition                    String?
  wastePercent                 Decimal   @default(0) @map("waste_percent") @db.Decimal(5, 2)
  roundType                    RoundType @default(NONE) @map("round_type")
  roundValue                   Decimal?  @map("round_value") @db.Decimal(15, 4)
  note                         String?
  displayOrder                 Int       @default(0) @map("display_order")
  createdAt                    DateTime  @default(now()) @map("created_at")
  updatedAt                    DateTime  @updatedAt @map("updated_at")

  materialRequirementVersion MaterialRequirementVersion @relation(fields: [materialRequirementVersionId], references: [id], onDelete: Cascade)
  material                   Material                   @relation(fields: [materialId], references: [id])

  @@index([materialRequirementVersionId])
  @@index([materialId])
  @@map("material_requirement_items")
}

// ──────────────────────────────────────
// Validation Rule & Derived Parameter (Sprint 03 Task 04)
// ──────────────────────────────────────

// Ràng buộc kích thước/cấu hình khi tạo báo giá. Expression mô tả điều kiện
// VI PHẠM (true → cảnh báo/chặn). Ví dụ hệ xích: height > 2 * width.
// Nghiệp vụ hiện tại chỉ dùng WARN (chốt 10/07/2026); BLOCK để sẵn cho tương lai.
model ValidationRule {
  id           String             @id @default(cuid())
  productId    String             @map("product_id")
  expression   String
  severity     ValidationSeverity @default(WARN)
  message      String
  displayOrder Int                @default(0) @map("display_order")
  createdAt    DateTime           @default(now()) @map("created_at")
  updatedAt    DateTime           @updatedAt @map("updated_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, displayOrder])
  @@map("validation_rules")
}

// Biến phái sinh tính từ tham số gốc, định nghĩa MỘT chỗ, cấp cho cả Pricing
// lẫn BOM. Ví dụ: area = chieurong * chieucao (kích thước nhập theo mét, m²).
model DerivedParameter {
  id           String   @id @default(cuid())
  productId    String   @map("product_id")
  name         String
  expression   String
  unit         String?
  displayOrder Int      @default(0) @map("display_order")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, name])
  @@index([productId, displayOrder])
  @@map("derived_parameters")
}

// ──────────────────────────────────────
// Customer
// ──────────────────────────────────────

model Customer {
  id          String  @id @default(cuid())
  code        String  @unique
  name        String
  phone       String  @unique
  email       String?
  // Thông tin doanh nghiệp (testlan1, chốt 08/07/2026) — khách công ty cần
  // tên công ty + mã số thuế để xuất hoá đơn; khách lẻ để trống.
  companyName String? @map("company_name")
  taxCode     String? @map("tax_code")
  province    String?
  district    String?
  ward        String?
  address     String?

  customerGroupId String? @map("customer_group_id")
  deliveryRouteId String? @map("delivery_route_id")
  saleId          String? @map("sale_id")

  priority     Priority       @default(MEDIUM)
  status       CustomerStatus @default(ACTIVE)
  debtLimit    Decimal        @default(0) @map("debt_limit") @db.Decimal(15, 0)
  debtTermDays Int            @default(30) @map("debt_term_days")
  note         String?

  createdBy String?   @map("created_by")
  updatedBy String?   @map("updated_by")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  customerGroup    CustomerGroup?            @relation(fields: [customerGroupId], references: [id])
  deliveryRoute    DeliveryRoute?            @relation(fields: [deliveryRouteId], references: [id])
  sale             User?                     @relation("CustomerSale", fields: [saleId], references: [id])
  createdByUser    User?                     @relation("CustomerCreatedBy", fields: [createdBy], references: [id])
  updatedByUser    User?                     @relation("CustomerUpdatedBy", fields: [updatedBy], references: [id])
  quotations       Quotation[]
  productDiscounts CustomerProductDiscount[]

  @@index([customerGroupId])
  @@index([deliveryRouteId])
  @@index([saleId])
  @@index([status])
  @@index([deletedAt])
  @@map("customers")
}

// ──────────────────────────────────────
// Quotation
// ──────────────────────────────────────

model Quotation {
  id           String          @id @default(cuid())
  code         String          @unique
  customerId   String          @map("customer_id")
  status       QuotationStatus @default(DRAFT)
  expiryDate   DateTime?       @map("expiry_date")
  // Hạn giao hàng thoả thuận với khách (Sprint 04, fix 19/07/2026) — nhập tay
  // lúc tạo/sửa báo giá (DRAFT/SENT). Snapshot sang SalesOrder.expectedDeliveryDate
  // tại Approve — sau đó Quotation không còn là nguồn đọc nữa.
  expectedDeliveryDate DateTime? @map("expected_delivery_date")
  note         String?
  salesOrderId String?         @unique @map("sales_order_id")

  createdBy String?  @map("created_by")
  updatedBy String?  @map("updated_by")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Giảm thêm cấp toàn báo giá (Sprint 04, chốt 16/07/2026) — chuyển từ cấp dòng
  // sản phẩm lên đây, chỉ giảm bằng số tiền mặt, áp trên Tổng thanh toán (đã
  // gồm VAT). Action POST /quotations/:id/discount, chỉ khi DRAFT/SENT.
  discountAmount Decimal @default(0) @map("discount_amount") @db.Decimal(15, 0)
  discountReason String? @map("discount_reason")
  discountBy     String? @map("discount_by")

  customer   Customer            @relation(fields: [customerId], references: [id])
  salesOrder SalesOrder?         @relation(fields: [salesOrderId], references: [id])
  items      QuotationItem[]
  timeline   QuotationTimeline[]

  @@index([customerId])
  @@index([status])
  @@index([salesOrderId])
  @@index([expiryDate])
  @@map("quotations")
}

model QuotationItem {
  id          String @id @default(cuid())
  quotationId String @map("quotation_id")
  productId   String @map("product_id")

  // Snapshot tại thời điểm thêm/sửa dòng (Architecture Review 05/07/2026 — sửa
  // vi phạm Snapshot Rule): hiển thị/in báo giá đọc từ đây, không đọc lại
  // Product. productId chỉ dùng điều hướng (xem quotation.md).
  productCode String @map("product_code")
  productName String @map("product_name")

  quantity Decimal @db.Decimal(15, 4)

  pricingRuleVersionId         String? @map("pricing_rule_version_id")
  materialRequirementVersionId String? @map("material_requirement_version_id")

  systemPrice     Decimal  @default(0) @map("system_price") @db.Decimal(15, 0)
  // Đơn giá/m² tra từ Price Matrix tại thời điểm tính giá (PricingEngineService)
  // — null khi sản phẩm không dùng Matrix (Expression fallback). Chỉ để hiển
  // thị trên bản in ("Giá bán"), không dùng để tính lại systemPrice/subtotal.
  unitPrice       Decimal? @map("unit_price") @db.Decimal(15, 0)
  // Snapshot % từ CustomerProductDiscount(customerId, productId) tại thời điểm
  // thêm/sửa dòng (Sprint 04, chốt 16/07/2026) — THAY THẾ groupDiscount
  // ("CK nhóm") + additionalDiscountPercent/Amount/discountReason/discountBy cũ.
  discountPercent Decimal  @default(0) @map("discount_percent") @db.Decimal(5, 2)
  // Phụ phí cộng SAU khi áp discountPercent (PricingRuleVersion.surchargeExpression,
  // Sprint 04 — 023). Snapshot tại thời điểm thêm/sửa dòng, không tính lại khi
  // chỉ đổi số lượng. finalPrice = systemPrice × (1 − discountPercent%) + surchargeAfterDiscount.
  surchargeAfterDiscount Decimal @default(0) @map("surcharge_after_discount") @db.Decimal(15, 0)
  finalPrice      Decimal  @default(0) @map("final_price") @db.Decimal(15, 0)
  subtotal        Decimal  @default(0) @db.Decimal(15, 0)

  // VAT (%) — snapshot từ PricingRuleVersion.vatRate tại thời điểm tính giá.
  // vatAmount tính SAU Discount Engine: round(subtotal × vatRate / 100).
  vatRate   Decimal @default(0) @map("vat_rate") @db.Decimal(5, 2)
  vatAmount Decimal @default(0) @map("vat_amount") @db.Decimal(15, 0)

  // Snapshot cảnh báo Validation Rule (WARN) tại thời điểm tính giá dòng này
  // (Sprint 03 Task 06) — mảng string, in được trên báo giá, không đọc lại rule.
  warnings Json?

  // Chú thích tay nhập thêm (Sprint 04, chốt 16/07/2026) — hiển thị cạnh warnings
  // ở cột "Chú thích" trên bảng dòng báo giá và bản in.
  note String?

  displayOrder Int      @default(0) @map("display_order")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  quotation  Quotation                @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  product    Product                  @relation(fields: [productId], references: [id])
  parameters QuotationItemParameter[]

  @@index([quotationId])
  @@index([productId])
  @@map("quotation_items")
}

model QuotationItemParameter {
  id              String   @id @default(cuid())
  quotationItemId String   @map("quotation_item_id")
  name            String
  label           String
  value           String
  // Nhãn hiển thị của option ENUM đã chọn — xem ghi chú ở
  // SalesOrderItemParameter.valueLabel (009-in-phieu-san-xuat.md).
  valueLabel      String?  @map("value_label")
  unit            String?
  displayOrder    Int      @default(0) @map("display_order")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  quotationItem QuotationItem @relation(fields: [quotationItemId], references: [id], onDelete: Cascade)

  @@index([quotationItemId])
  @@map("quotation_item_parameters")
}

model QuotationTimeline {
  id            String                  @id @default(cuid())
  quotationId   String                  @map("quotation_id")
  action        QuotationTimelineAction
  payload       Json?
  createdBy     String?                 @map("created_by")
  // Snapshot tên tại thời điểm ghi timeline (Sprint 04, 005-nguoi-thuc-hien-lich-su-hoat-dong.md).
  createdByName String?                 @map("created_by_name")
  createdAt     DateTime                @default(now()) @map("created_at")

  quotation     Quotation @relation(fields: [quotationId], references: [id])
  createdByUser User?     @relation(fields: [createdBy], references: [id], onDelete: SetNull)

  @@index([quotationId])
  @@index([quotationId, createdAt])
  @@map("quotation_timelines")
}

// ──────────────────────────────────────
// Sales Order (generated from Quotation.approve)
// ──────────────────────────────────────

model SalesOrder {
  id            String           @id @default(cuid())
  code          String           @unique
  quotationCode String           @map("quotation_code")
  customerId    String           @map("customer_id")
  customerName  String           @map("customer_name")
  customerPhone String           @map("customer_phone")

  // Địa chỉ giao hàng (Sprint 04, 009-in-phieu-san-xuat.md) — auto copy từ
  // Customer tại Approve, KHÔNG đọc lại Customer sau đó. Khác nhóm field
  // tài chính/BOM/thông số bị khoá ở "Immutable Document" (order.md): đây là
  // dữ liệu vận hành/logistics, cho sửa qua action updateDeliveryAddress()
  // (không bắt buộc lý do, sửa được ở mọi Status) vì một Customer có thể giao
  // nhiều địa chỉ khác nhau cho từng đơn (nhiều công trình).
  deliveryName     String  @map("delivery_name")
  deliveryPhone    String  @map("delivery_phone")
  deliveryAddress  String? @map("delivery_address")
  deliveryProvince String? @map("delivery_province")
  deliveryDistrict String? @map("delivery_district")
  deliveryWard     String? @map("delivery_ward")

  // Thông tin nhà xe/vận chuyển (Sprint 04, 009-in-phieu-san-xuat.md) — KHÁC
  // nhóm delivery* ở trên: đây là nhà xe/tài xế chở hàng, không phải người/
  // nơi nhận hàng. Không có nguồn Master Data để auto-copy (không giống
  // delivery* copy từ Customer) — mặc định NULL, nhập tay qua action
  // updateCarrierInfo() khi đã sắp xếp được xe (không bắt buộc lý do, sửa
  // được ở mọi Status, cùng cơ chế Timeline với delivery*).
  carrierName  String? @map("carrier_name")
  carrierPhone String? @map("carrier_phone")
  carrierNote  String? @map("carrier_note")

  status        SalesOrderStatus @default(IN_PRODUCTION)
  totalAmount   Decimal          @map("total_amount") @db.Decimal(15, 0)
  plannedCost   Decimal          @map("planned_cost") @db.Decimal(15, 0)
  plannedProfit Decimal          @map("planned_profit") @db.Decimal(15, 0)
  // FK → users, set tại Approve = người tạo báo giá (Quotation.createdBy) —
  // phục vụ Báo cáo doanh số theo nhân viên (report.md C1). Nullable: dữ liệu
  // trước Architecture Review 05/07/2026 không xác định được, để NULL.
  ownerId       String?          @map("owner_id")
  // Snapshot hiển thị — giữ nguyên kể cả khi User đổi tên sau này.
  ownerName     String?          @map("owner_name")

  totalProductionOrders     Int @map("total_production_orders")
  completedProductionOrders Int @default(0) @map("completed_production_orders")

  expectedDeliveryDate DateTime? @map("expected_delivery_date")
  actualDeliveryDate   DateTime? @map("actual_delivery_date")

  paymentStatus PaymentStatus @default(UNPAID) @map("payment_status")

  // VAT + Giảm thêm (Sprint 04, chốt 16/07/2026) — snapshot tại Approve từ
  // Quotation. totalAmount (doanh thu) giữ nguyên công thức cũ, KHÔNG cộng
  // VAT/trừ Giảm thêm. grandTotal là Derived Data hợp lệ (Snapshot,
  // Nguyên tắc 13) — số tiền hoá đơn thực tế, bất biến sau Approve.
  totalVatAmount Decimal @default(0) @map("total_vat_amount") @db.Decimal(15, 0)
  discountAmount Decimal @default(0) @map("discount_amount") @db.Decimal(15, 0)
  discountReason String? @map("discount_reason")
  discountBy     String? @map("discount_by")
  grandTotal     Decimal @default(0) @map("grand_total") @db.Decimal(15, 0)

  note      String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  owner            User?                @relation(fields: [ownerId], references: [id])
  quotation        Quotation?
  items            SalesOrderItem[]
  productionOrders ProductionOrder[]
  timeline         SalesOrderTimeline[]
  receivable       Receivable?
  returns          Return[]

  @@index([customerId])
  @@index([status])
  @@index([paymentStatus])
  // Dashboard (009-dashboard.md Task 06) — getDelayedOrders() lọc theo expectedDeliveryDate.
  @@index([expectedDeliveryDate])
  // Báo cáo (report.md mục 3) — các report doanh thu lọc/gom theo ngày tạo đơn.
  @@index([createdAt])
  @@map("sales_orders")
}

model SalesOrderItem {
  id           String @id @default(cuid())
  salesOrderId String @map("sales_order_id")

  productId            String @map("product_id")
  productCode          String @map("product_code")
  productName          String @map("product_name")
  // Redundant Reference (productTypeId) + snapshot (productTypeName) phục vụ
  // Báo cáo B2/B4 (report.md) — set tại Approve, không đọc lại Master Data
  // sau khi tạo. Không dùng @relation, cùng convention productId.
  productTypeId        String @map("product_type_id")
  productTypeName      String @map("product_type_name")
  productionCenterId   String @map("production_center_id")
  productionCenterName String @map("production_center_name")

  pricingRuleVersionId String?  @map("pricing_rule_version_id")
  systemPrice          Decimal  @map("system_price") @db.Decimal(15, 0)
  // Snapshot từ QuotationItem.unitPrice tại Approve — đơn giá/m² tra từ Price
  // Matrix, null khi sản phẩm không dùng Matrix. Chỉ để hiển thị bản in.
  unitPrice            Decimal? @map("unit_price") @db.Decimal(15, 0)
  // Snapshot từ QuotationItem.discountPercent tại Approve (Sprint 04, chốt
  // 16/07/2026) — THAY THẾ groupDiscount + additionalDiscountPercent/Amount cũ.
  discountPercent      Decimal  @default(0) @map("discount_percent") @db.Decimal(5, 2)
  // Snapshot từ QuotationItem.surchargeAfterDiscount tại Approve (Sprint 04 —
  // 023) — không tính lại, y hệt cách finalPrice được snapshot.
  surchargeAfterDiscount Decimal @default(0) @map("surcharge_after_discount") @db.Decimal(15, 0)
  finalPrice           Decimal  @map("final_price") @db.Decimal(15, 0)
  quantity             Decimal  @db.Decimal(15, 4)
  subtotal             Decimal  @db.Decimal(15, 0)

  // VAT snapshot từ QuotationItem tại Approve.
  vatRate   Decimal @default(0) @map("vat_rate") @db.Decimal(5, 2)
  vatAmount Decimal @default(0) @map("vat_amount") @db.Decimal(15, 0)

  // Chú thích snapshot từ QuotationItem.note tại Approve.
  note String?

  materialRequirementVersionId String? @map("material_requirement_version_id")
  plannedCost                  Decimal @default(0) @map("planned_cost") @db.Decimal(15, 0)

  displayOrder Int      @default(0) @map("display_order")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  salesOrder SalesOrder                @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)
  parameters SalesOrderItemParameter[]
  bom        OrderBOM?

  @@index([salesOrderId])
  // Báo cáo (report.md mục 3) — gom doanh thu theo sản phẩm/loại sản phẩm.
  @@index([productId])
  @@index([productTypeId])
  @@map("sales_order_items")
}

model SalesOrderItemParameter {
  id               String   @id @default(cuid())
  salesOrderItemId String   @map("sales_order_item_id")
  name             String
  label            String
  value            String
  // Nhãn hiển thị của option ENUM đã chọn (vd "Cửa sổ" cho value "cuaso") —
  // snapshot từ ProductParameterOption.label tại thời điểm thêm/sửa dòng báo
  // giá (009-in-phieu-san-xuat.md). Null với tham số không phải ENUM hoặc
  // option không còn nhãn. `value` giữ nguyên mã gốc (dùng cho Pricing Engine/
  // Expression) — trường này CHỈ phục vụ hiển thị, không dùng để tính toán.
  valueLabel       String?  @map("value_label")
  unit             String?
  displayOrder     Int      @default(0) @map("display_order")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  salesOrderItem SalesOrderItem @relation(fields: [salesOrderItemId], references: [id], onDelete: Cascade)

  @@index([salesOrderItemId])
  @@map("sales_order_item_parameters")
}

// ──────────────────────────────────────
// Order BOM (snapshot of Material Requirement)
// ──────────────────────────────────────

model OrderBOM {
  id                           String   @id @default(cuid())
  salesOrderId                 String   @map("sales_order_id")
  salesOrderItemId             String   @unique @map("sales_order_item_id")
  materialRequirementVersionId String   @map("material_requirement_version_id")
  plannedCost                  Decimal  @default(0) @map("planned_cost") @db.Decimal(15, 0)
  createdAt                    DateTime @default(now()) @map("created_at")
  updatedAt                    DateTime @updatedAt @map("updated_at")

  salesOrderItem SalesOrderItem @relation(fields: [salesOrderItemId], references: [id], onDelete: Cascade)
  items          OrderBOMItem[]

  @@index([salesOrderId])
  @@map("order_boms")
}

model OrderBOMItem {
  id           String    @id @default(cuid())
  orderBOMId   String    @map("order_bom_id")
  materialId   String    @map("material_id")
  materialCode String    @map("material_code")
  materialName String    @map("material_name")
  materialUnit String?   @map("material_unit")
  expression   String
  wastePercent Decimal   @default(0) @map("waste_percent") @db.Decimal(5, 2)
  roundType    RoundType @default(NONE) @map("round_type")
  roundValue   Decimal?  @map("round_value") @db.Decimal(15, 4)
  quantity     Decimal   @db.Decimal(15, 4)
  unitPrice    Decimal   @default(0) @map("unit_price") @db.Decimal(15, 2)
  lineTotal    Decimal   @default(0) @map("line_total") @db.Decimal(15, 0)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  orderBOM OrderBOM @relation(fields: [orderBOMId], references: [id], onDelete: Cascade)

  @@index([orderBOMId])
  @@map("order_bom_items")
}

// ──────────────────────────────────────
// Sales Order Timeline (audit log)
// ──────────────────────────────────────

model SalesOrderTimeline {
  id            String                      @id @default(cuid())
  salesOrderId  String                      @map("sales_order_id")
  action        SalesOrderTimelineAction
  actorType     SalesOrderTimelineActorType @map("actor_type")
  payload       Json?
  createdBy     String?                     @map("created_by")
  // Snapshot tên tại thời điểm ghi timeline (Sprint 04, 005-nguoi-thuc-hien-lich-su-hoat-dong.md).
  createdByName String?                     @map("created_by_name")
  createdAt     DateTime                    @default(now()) @map("created_at")

  salesOrder    SalesOrder @relation(fields: [salesOrderId], references: [id])
  createdByUser User?      @relation(fields: [createdBy], references: [id], onDelete: SetNull)

  @@index([salesOrderId])
  @@index([salesOrderId, createdAt])
  @@map("sales_order_timelines")
}

// ──────────────────────────────────────
// Production Order
// ──────────────────────────────────────

model ProductionOrder {
  id                   String                @id @default(cuid())
  code                 String                @unique
  salesOrderId         String                @map("sales_order_id")
  productionCenterId   String                @map("production_center_id")
  productionCenterName String                @map("production_center_name")
  status               ProductionOrderStatus @default(PENDING)
  startedAt            DateTime?             @map("started_at")
  completedAt          DateTime?             @map("completed_at")
  createdAt            DateTime              @default(now()) @map("created_at")
  updatedAt            DateTime              @updatedAt @map("updated_at")

  salesOrder            SalesOrder                @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)
  items                 ProductionOrderItem[]
  timeline              ProductionOrderTimeline[]
  warehouseTransactions WarehouseTransaction[]

  @@index([salesOrderId])
  @@index([productionCenterId])
  @@index([status])
  @@map("production_orders")
}

model ProductionOrderItem {
  id                String   @id @default(cuid())
  productionOrderId String   @map("production_order_id")
  salesOrderItemId  String   @map("sales_order_item_id")
  productId         String   @map("product_id")
  productCode       String   @map("product_code")
  productName       String   @map("product_name")
  quantity          Decimal  @db.Decimal(15, 4)
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  productionOrder ProductionOrder @relation(fields: [productionOrderId], references: [id], onDelete: Cascade)

  @@index([productionOrderId])
  @@map("production_order_items")
}

// ──────────────────────────────────────
// Production Order Timeline (audit log)
// ──────────────────────────────────────

model ProductionOrderTimeline {
  id                String                           @id @default(cuid())
  productionOrderId String                           @map("production_order_id")
  action            ProductionOrderTimelineAction
  actorType         ProductionOrderTimelineActorType @map("actor_type")
  payload           Json?
  createdBy         String?                          @map("created_by")
  // Snapshot tên tại thời điểm ghi timeline (Sprint 04, 005-nguoi-thuc-hien-lich-su-hoat-dong.md).
  createdByName     String?                          @map("created_by_name")
  createdAt         DateTime                         @default(now()) @map("created_at")

  productionOrder ProductionOrder @relation(fields: [productionOrderId], references: [id])
  createdByUser   User?           @relation(fields: [createdBy], references: [id], onDelete: SetNull)

  @@index([productionOrderId])
  @@index([productionOrderId, createdAt])
  @@map("production_order_timelines")
}

// ──────────────────────────────────────
// Warehouse (Material Receipt / Warehouse Transaction)
// ──────────────────────────────────────

// Header — một phiếu có thể gồm nhiều vật tư (Sprint 04, chốt 16/07/2026).
// Chi tiết từng vật tư nằm ở MaterialReceiptItem.
model MaterialReceipt {
  id            String   @id @default(cuid())
  code          String   @unique
  supplierName  String?  @map("supplier_name")
  note          String?
  createdBy     String?  @map("created_by")
  // Snapshot tên tại thời điểm tạo phiếu (Sprint 04, 005-nguoi-thuc-hien-lich-su-hoat-dong.md).
  createdByName String?  @map("created_by_name")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  items         MaterialReceiptItem[]
  createdByUser User?                 @relation(fields: [createdBy], references: [id], onDelete: SetNull)

  // Báo cáo (report.md mục 3) — báo cáo nhập kho lọc theo ngày tạo phiếu.
  @@index([createdAt])
  @@map("material_receipts")
}

model MaterialReceiptItem {
  id                String   @id @default(cuid())
  materialReceiptId String   @map("material_receipt_id")
  materialId        String   @map("material_id")
  materialCode      String   @map("material_code")
  materialName      String   @map("material_name")
  unit              String
  quantity          Decimal  @db.Decimal(15, 4)
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  materialReceipt MaterialReceipt       @relation(fields: [materialReceiptId], references: [id], onDelete: Cascade)
  material        Material              @relation(fields: [materialId], references: [id])
  transaction     WarehouseTransaction?

  @@index([materialReceiptId])
  @@index([materialId])
  @@map("material_receipt_items")
}

model WarehouseTransaction {
  id                    String                   @id @default(cuid())
  direction             WarehouseDirection
  transactionType       WarehouseTransactionType @map("transaction_type")
  materialId            String                   @map("material_id")
  materialCode          String                   @map("material_code")
  materialName          String                   @map("material_name")
  unit                  String
  quantity              Decimal                  @db.Decimal(15, 4)
  materialReceiptItemId String?                  @unique @map("material_receipt_item_id")
  productionOrderId     String?                  @map("production_order_id")
  createdAt             DateTime                 @default(now()) @map("created_at")

  material            Material             @relation(fields: [materialId], references: [id])
  materialReceiptItem MaterialReceiptItem? @relation(fields: [materialReceiptItemId], references: [id])
  productionOrder     ProductionOrder?     @relation(fields: [productionOrderId], references: [id])

  // Idempotency (Task 03/07): một Production Order chỉ xuất kho đúng một lần cho mỗi vật tư —
  // enforce ở DB, không chỉ dựa vào validate status = PENDING ở tầng application.
  @@unique([productionOrderId, materialId])
  @@index([materialId])
  @@index([productionOrderId])
  // Dashboard (009-dashboard.md Task 07) — WarehouseService.getTopConsumedMaterials()
  // lọc theo direction/transactionType/createdAt trước khi GROUP BY materialId.
  @@index([transactionType, direction, createdAt])
  @@map("warehouse_transactions")
}

// ──────────────────────────────────────
// Debt (Accounts Receivable)
// ──────────────────────────────────────

model Receivable {
  id           String @id @default(cuid())
  salesOrderId String @unique @map("sales_order_id")
  // Redundant reference (copy ID bất biến, không phải Derived Data) — tránh
  // join qua SalesOrder cho các query tổng hợp theo khách hàng (Debt Monitoring).
  // Không dùng @relation, cùng convention với SalesOrder.customerId.
  customerId   String @map("customer_id")

  totalAmount     Decimal @map("total_amount") @db.Decimal(15, 0)
  paidAmount      Decimal @default(0) @map("paid_amount") @db.Decimal(15, 0)
  // Derived (totalAmount - paidAmount) nhưng được phép lưu — lý do hiệu năng đọc
  // (Dashboard/Debt Monitoring), cập nhật atomic trong PaymentService.create().
  // CHECK (remaining_amount >= 0) khai báo tay trong migration.sql.
  remainingAmount Decimal @map("remaining_amount") @db.Decimal(15, 0)

  // Credit Policy Snapshot — copy từ Customer.debtLimit/debtTermDays tại thời điểm tạo.
  debtLimitSnapshot    Decimal @map("debt_limit_snapshot") @db.Decimal(15, 0)
  debtTermDaysSnapshot Int     @map("debt_term_days_snapshot")

  // NULL lúc tạo, set = actualDeliveryDate + debtTermDaysSnapshot khi SalesOrder Delivered.
  dueDate DateTime? @map("due_date")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  salesOrder SalesOrder @relation(fields: [salesOrderId], references: [id])
  payments   Payment[]

  @@index([customerId])
  // Dashboard (009-dashboard.md Task 07) — overdue/risk/upcoming-due đều lọc theo dueDate.
  @@index([dueDate])
  @@map("receivables")
}

model Payment {
  id           String @id @default(cuid())
  code         String @unique
  // Redundant reference giữ cùng receivableId — lý do hiệu năng, tránh join
  // qua Receivable mỗi lần cần salesOrderId. Không dùng @relation (cùng
  // convention với các field redundant reference khác trong schema).
  salesOrderId String @map("sales_order_id")
  receivableId String @map("receivable_id")

  paymentDate     DateTime      @map("payment_date")
  amount          Decimal       @db.Decimal(15, 0)
  paymentMethod   PaymentMethod @map("payment_method")
  referenceNumber String?       @map("reference_number")
  note            String?
  createdBy       String?       @map("created_by")
  createdAt       DateTime      @default(now()) @map("created_at")

  receivable Receivable @relation(fields: [receivableId], references: [id])

  @@index([salesOrderId])
  @@index([receivableId])
  // Báo cáo (report.md mục 3) — báo cáo thu tiền lọc theo ngày thanh toán.
  @@index([paymentDate])
  @@map("payments")
}

// ──────────────────────────────────────
// Settings
// ──────────────────────────────────────

// Singleton — chỉ đúng một bản ghi, seed sẵn ở migration/seed. Không có
// Create/Delete API (xem setting.md mục "Company Settings").
model Company {
  id                String   @id @default(cuid())
  companyName       String   @map("company_name")
  logo              String?
  // Ảnh con dấu công ty (base64) — chèn đè lên ô ký "Đại diện công ty" khi in
  // Báo giá/Xác nhận đơn hàng.
  stamp             String?
  address           String?
  phone             String?
  email             String?
  website           String?
  taxCode           String?  @map("tax_code")
  // Thông tin ngân hàng hiển thị ở Block "Thông tin thanh toán" trên bản in
  // Báo giá/Xác nhận đơn hàng.
  bankName          String?  @map("bank_name")
  bankAccountNumber String?  @map("bank_account_number")
  bankAccountHolder String?  @map("bank_account_holder")
  // Chỉ là nhãn hiển thị, không phải công tắc đa tiền tệ — xem setting.md.
  currency          String   @default("VND")
  currencySymbol    String   @default("₫") @map("currency_symbol")
  timezone          String   @default("Asia/Ho_Chi_Minh")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@map("companies")
}

// Key-value dùng chung cho Dashboard/Notification/Document/Security/Backup
// Settings — chỉ giá trị Loại 1 (xem setting.md mục "Phân loại cấu hình").
// value/defaultValue lưu dạng String, FE/BE tự parse theo valueType.
model Setting {
  id           String           @id @default(cuid())
  module       String
  key          String
  value        String
  defaultValue String           @map("default_value")
  valueType    SettingValueType @map("value_type")
  description  String?
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")

  @@unique([module, key])
  @@index([module])
  @@map("settings")
}

// ──────────────────────────────────────
// Return (Recovery Management)
// ──────────────────────────────────────

model Return {
  id              String       @id @default(cuid())
  code            String       @unique
  salesOrderId    String       @map("sales_order_id")
  salesOrderCode  String       @map("sales_order_code")
  // Redundant reference (copy ID bất biến, không phải Derived Data) — tránh
  // join qua SalesOrder cho thống kê "Return theo khách hàng". Không dùng
  // @relation, cùng convention với SalesOrder.customerId/Receivable.customerId.
  customerId      String       @map("customer_id")
  customerName    String       @map("customer_name")
  // Một chiều PROCESSING → COMPLETED qua POST /returns/:id/complete
  // (return.md mục "Trạng thái Return").
  status          ReturnStatus @default(PROCESSING)
  // Ghi nhận Action complete (đã chốt 06/07/2026): người thực hiện + thời điểm.
  // NULL với bản ghi backfill COMPLETED trước khi có trạng thái.
  completedBy     String?      @map("completed_by")
  // Snapshot tên tại thời điểm hoàn thành (Sprint 04, 005-nguoi-thuc-hien-lich-su-hoat-dong.md).
  completedByName String?      @map("completed_by_name")
  completedAt     DateTime?    @map("completed_at")
  returnDate      DateTime     @map("return_date")
  receivedBy      String?      @map("received_by")
  note            String?

  // Giá trị phiếu hoàn — CHỈ THAM KHẢO, đã gồm VAT (Sprint 04 rà soát bộ lọc,
  // chốt 18/07/2026). Snapshot 1 lần tại create(), tính từ tổng từng dòng:
  // round(ReturnItem.unitPriceSnapshot × returnedQuantity) + VAT tương ứng
  // (ReturnItem.vatRate). Return KHÔNG tự động dùng số này để trừ Công nợ —
  // kế toán tự đọc số này rồi qua module Công nợ tạo Điều chỉnh thủ công nếu
  // quyết định giảm nợ cho khách (xem return.md mục Ghi chú).
  totalValue Decimal @default(0) @map("total_value") @db.Decimal(15, 0)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  salesOrder      SalesOrder   @relation(fields: [salesOrderId], references: [id])
  items           ReturnItem[]
  completedByUser User?        @relation(fields: [completedBy], references: [id], onDelete: SetNull)

  @@index([salesOrderId])
  @@index([customerId])
  // Báo cáo (report.md mục 3) — thống kê Return lọc theo ngày hoàn.
  @@index([returnDate])
  @@map("returns")
}

model ReturnItem {
  id               String @id @default(cuid())
  returnId         String @map("return_id")
  // Chỉ dùng để điều hướng dữ liệu (navigation) — không đọc lại SalesOrderItem
  // sau khi tạo. Không dùng @relation, cùng convention với
  // ProductionOrderItem.salesOrderItemId (xem production.md).
  salesOrderItemId String @map("sales_order_item_id")

  productCode       String       @map("product_code")
  productName       String       @map("product_name")
  productParameters Json?        @map("product_parameters")
  orderedQuantity   Decimal      @map("ordered_quantity") @db.Decimal(15, 4)
  returnedQuantity  Decimal      @map("returned_quantity") @db.Decimal(15, 4)
  // Snapshot từ SalesOrderItem.finalPrice — không đọc lại sau khi tạo.
  unitPriceSnapshot Decimal      @map("unit_price_snapshot") @db.Decimal(15, 0)
  // Snapshot từ SalesOrderItem.vatRate (%) — dùng để tính Return.totalValue.
  vatRate           Decimal      @default(0) @map("vat_rate") @db.Decimal(5, 2)
  reason            ReturnReason
  note              String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  return            Return             @relation(fields: [returnId], references: [id], onDelete: Cascade)
  recoveryInventory RecoveryInventory?

  @@index([returnId])
  @@index([salesOrderItemId])
  @@map("return_items")
}

model RecoveryInventory {
  id                    String @id @default(cuid())
  code                  String @unique
  returnItemId          String @unique @map("return_item_id")
  // Redundant reference tới Return.code tại thời điểm tạo — tránh join
  // returnItemId → ReturnItem → Return mỗi lần hiển thị (xem return.md).
  createdFromReturnCode String @map("created_from_return_code")

  productCode       String                  @map("product_code")
  productName       String                  @map("product_name")
  productParameters Json?                   @map("product_parameters")
  quantity          Decimal                 @db.Decimal(15, 4)
  location          String?
  status            RecoveryInventoryStatus @default(AVAILABLE)
  // Chỉ lưu URL, không xây hạ tầng upload ở V1 (xem setting.md "Future Policies").
  imageUrl          String?                 @map("image_url")
  // Ghi kèm khi mark-used (Task 05) — không FK, chỉ để thống kê tự do.
  usedForNote       String?                 @map("used_for_note")

  // Dùng làm mốc tính "Hàng tồn lâu" — không có receivedDate riêng (xem return.md).
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  returnItem ReturnItem @relation(fields: [returnItemId], references: [id])

  @@index([status])
  @@index([status, createdAt])
  @@map("recovery_inventories")
}
