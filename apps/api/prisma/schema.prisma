generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ──────────────────────────────────────
// Enum
// ──────────────────────────────────────

enum Priority {
  LOW
  MEDIUM
  HIGH
}

enum CustomerStatus {
  ACTIVE
  INACTIVE
}

enum ProductStatus {
  DRAFT
  ACTIVE
  INACTIVE
}

enum ParameterType {
  NUMBER
  TEXT
  ENUM
  BOOLEAN
}

enum VersionStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum RoundType {
  NONE
  CEIL
  FLOOR
  ROUND
}

enum PricingRuleType {
  MIN_AREA
  MIN_DIMENSION
  MIN_VALUE
  ROUND
  CUSTOM
}

enum QuotationStatus {
  DRAFT
  SENT
  APPROVED
  CANCELLED
}

enum QuotationTimelineAction {
  QUOTATION_CREATED
  QUOTATION_SENT
  QUOTATION_APPROVED
  QUOTATION_CANCELLED
  QUOTATION_MANUAL_OVERRIDE
}

enum SalesOrderStatus {
  IN_PRODUCTION
  PRODUCTION_COMPLETED
  SHIPPED
  DELIVERED
  CANCELLED
}

enum ProductionOrderStatus {
  PENDING
  IN_PRODUCTION
  PRODUCTION_COMPLETED
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  PARTIALLY_PAID
  PAID
}

enum SalesOrderTimelineActorType {
  SYSTEM
  USER
}

enum SalesOrderTimelineAction {
  SALES_ORDER_CREATED
  PRODUCTION_ORDERS_GENERATED
  PRODUCTION_COMPLETED
  SHIPPED
  DELIVERED
  PAYMENT_STATUS_CHANGED
  MANUAL_OVERRIDE
  CANCELLED
}

// Enum riêng cho Production, không tái sử dụng SalesOrderTimelineActorType —
// xem knowledge/modules/production.md mục ActorType.
enum ProductionOrderTimelineActorType {
  SYSTEM
  USER
}

enum ProductionOrderTimelineAction {
  PRODUCTION_ORDER_CREATED
  STARTED
  COMPLETED
  CANCELLED
}

enum WarehouseDirection {
  IN
  OUT
}

enum WarehouseTransactionType {
  MATERIAL_RECEIPT
  MATERIAL_ISSUE
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
}

enum SettingValueType {
  BOOLEAN
  NUMBER
  STRING
  TEXT
}

// ──────────────────────────────────────
// System
// ──────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  saleCustomers    Customer[] @relation("CustomerSale")
  createdCustomers Customer[] @relation("CustomerCreatedBy")
  updatedCustomers Customer[] @relation("CustomerUpdatedBy")

  @@map("users")
}

model RunningNumber {
  id            String   @id @default(cuid())
  type          String   @unique
  prefix        String
  lastNumber    Int      @default(0) @map("last_number")
  paddingLength Int      @default(6) @map("padding_length")
  // Chỉ ẩn/hiện loại chứng từ khỏi menu — không chặn tạo chứng từ (xem setting.md).
  enabled       Boolean  @default(true)
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("running_numbers")
}

// ──────────────────────────────────────
// Master Data
// ──────────────────────────────────────

model CustomerGroup {
  id              String   @id @default(cuid())
  name            String   @unique
  discountPercent Decimal  @default(0) @map("discount_percent") @db.Decimal(5, 2)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  customers Customer[]

  @@map("customer_groups")
}

model DeliveryRoute {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  customers Customer[]

  @@map("delivery_routes")
}

// ──────────────────────────────────────
// Production Center
// ──────────────────────────────────────

model ProductionCenter {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  products Product[]

  @@index([isActive])
  @@map("production_centers")
}

// ──────────────────────────────────────
// Unit & Product Type
// ──────────────────────────────────────

model Unit {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  materials Material[]
  products  Product[]

  @@map("units")
}

model ProductType {
  id        String   @id @default(cuid())
  name      String   @unique
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  products Product[]

  @@map("product_types")
}

// ──────────────────────────────────────
// Material
// ──────────────────────────────────────

model Material {
  id           String   @id @default(cuid())
  code         String   @unique
  name         String
  unitId       String   @map("unit_id")
  isActive     Boolean  @default(true) @map("is_active")
  note         String?
  currentStock Decimal  @default(0) @map("current_stock") @db.Decimal(15, 4)
  minimumStock Decimal? @map("minimum_stock") @db.Decimal(15, 4)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  unit             Unit                      @relation(fields: [unitId], references: [id])
  prices           MaterialPrice[]
  requirementItems MaterialRequirementItem[]
  receipts         MaterialReceipt[]
  transactions     WarehouseTransaction[]

  @@index([isActive])
  @@map("materials")
}

model MaterialPrice {
  id            String    @id @default(cuid())
  materialId    String    @map("material_id")
  supplierId    String?   @map("supplier_id")
  supplierName  String?   @map("supplier_name")
  price         Decimal   @db.Decimal(15, 2)
  effectiveFrom DateTime  @map("effective_from")
  effectiveTo   DateTime? @map("effective_to")
  isDefault     Boolean   @default(false) @map("is_default")
  note          String?
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  material Material @relation(fields: [materialId], references: [id])

  @@index([materialId])
  @@index([materialId, isDefault])
  @@index([materialId, effectiveFrom])
  @@map("material_prices")
}

// ──────────────────────────────────────
// Product
// ──────────────────────────────────────

model Product {
  id                 String        @id @default(cuid())
  code               String        @unique
  name               String
  productTypeId      String        @map("product_type_id")
  unitId             String        @map("unit_id")
  productionCenterId String        @map("production_center_id")
  status             ProductStatus @default(DRAFT)
  description        String?
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt @map("updated_at")
  deletedAt          DateTime?     @map("deleted_at")

  productType         ProductType          @relation(fields: [productTypeId], references: [id])
  unit                Unit                 @relation(fields: [unitId], references: [id])
  productionCenter    ProductionCenter     @relation(fields: [productionCenterId], references: [id])
  parameters          ProductParameter[]
  pricingRule         PricingRule?
  materialRequirement MaterialRequirement?
  quotationItems      QuotationItem[]

  @@index([productTypeId])
  @@index([productionCenterId])
  @@index([status])
  @@index([deletedAt])
  @@map("products")
}

model ProductParameter {
  id             String        @id @default(cuid())
  productId      String        @map("product_id")
  name           String
  label          String
  type           ParameterType
  unit           String?
  defaultValue   String?       @map("default_value")
  isRequired     Boolean       @default(false) @map("is_required")
  minValue       Decimal?      @map("min_value") @db.Decimal(15, 4)
  maxValue       Decimal?      @map("max_value") @db.Decimal(15, 4)
  step           Decimal?      @db.Decimal(15, 4)
  usedInPricing  Boolean       @default(true) @map("used_in_pricing")
  usedInMaterial Boolean       @default(true) @map("used_in_material")
  displayOrder   Int           @default(0) @map("display_order")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  product Product                  @relation(fields: [productId], references: [id])
  options ProductParameterOption[]

  @@unique([productId, name])
  @@index([productId, displayOrder])
  @@map("product_parameters")
}

model ProductParameterOption {
  id           String   @id @default(cuid())
  parameterId  String   @map("parameter_id")
  value        String
  label        String?
  displayOrder Int      @default(0) @map("display_order")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  parameter ProductParameter @relation(fields: [parameterId], references: [id], onDelete: Cascade)

  @@index([parameterId, displayOrder])
  @@map("product_parameter_options")
}

// ──────────────────────────────────────
// Pricing Rule
// ──────────────────────────────────────

model PricingRule {
  id        String   @id @default(cuid())
  productId String   @unique @map("product_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  product  Product              @relation(fields: [productId], references: [id])
  versions PricingRuleVersion[]

  @@map("pricing_rules")
}

model PricingRuleVersion {
  id              String        @id @default(cuid())
  pricingRuleId   String        @map("pricing_rule_id")
  versionNumber   Int           @map("version_number")
  name            String?
  expression      String?
  priceRoundType  RoundType     @default(NONE) @map("price_round_type")
  priceRoundValue Decimal?      @map("price_round_value") @db.Decimal(15, 0)
  status          VersionStatus @default(DRAFT)
  note            String?
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  pricingRule PricingRule       @relation(fields: [pricingRuleId], references: [id])
  items       PricingRuleItem[]

  @@unique([pricingRuleId, versionNumber])
  @@index([pricingRuleId, status])
  @@map("pricing_rule_versions")
}

model PricingRuleItem {
  id                   String          @id @default(cuid())
  pricingRuleVersionId String          @map("pricing_rule_version_id")
  ruleType             PricingRuleType @map("rule_type")
  targetParameter      String?         @map("target_parameter")
  value                Decimal         @db.Decimal(15, 4)
  displayOrder         Int             @default(0) @map("display_order")
  description          String?
  createdAt            DateTime        @default(now()) @map("created_at")
  updatedAt            DateTime        @updatedAt @map("updated_at")

  pricingRuleVersion PricingRuleVersion @relation(fields: [pricingRuleVersionId], references: [id], onDelete: Cascade)

  @@index([pricingRuleVersionId])
  @@map("pricing_rule_items")
}

// ──────────────────────────────────────
// Material Requirement
// ──────────────────────────────────────

model MaterialRequirement {
  id        String   @id @default(cuid())
  productId String   @unique @map("product_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  product  Product                      @relation(fields: [productId], references: [id])
  versions MaterialRequirementVersion[]

  @@map("material_requirements")
}

model MaterialRequirementVersion {
  id                    String        @id @default(cuid())
  materialRequirementId String        @map("material_requirement_id")
  versionNumber         Int           @map("version_number")
  name                  String?
  status                VersionStatus @default(DRAFT)
  note                  String?
  createdAt             DateTime      @default(now()) @map("created_at")
  updatedAt             DateTime      @updatedAt @map("updated_at")

  materialRequirement MaterialRequirement       @relation(fields: [materialRequirementId], references: [id])
  items               MaterialRequirementItem[]

  @@unique([materialRequirementId, versionNumber])
  @@index([materialRequirementId, status])
  @@map("material_requirement_versions")
}

model MaterialRequirementItem {
  id                           String    @id @default(cuid())
  materialRequirementVersionId String    @map("material_requirement_version_id")
  materialId                   String    @map("material_id")
  expression                   String
  wastePercent                 Decimal   @default(0) @map("waste_percent") @db.Decimal(5, 2)
  roundType                    RoundType @default(NONE) @map("round_type")
  roundValue                   Decimal?  @map("round_value") @db.Decimal(15, 4)
  note                         String?
  displayOrder                 Int       @default(0) @map("display_order")
  createdAt                    DateTime  @default(now()) @map("created_at")
  updatedAt                    DateTime  @updatedAt @map("updated_at")

  materialRequirementVersion MaterialRequirementVersion @relation(fields: [materialRequirementVersionId], references: [id], onDelete: Cascade)
  material                   Material                   @relation(fields: [materialId], references: [id])

  @@index([materialRequirementVersionId])
  @@index([materialId])
  @@map("material_requirement_items")
}

// ──────────────────────────────────────
// Customer
// ──────────────────────────────────────

model Customer {
  id       String  @id @default(cuid())
  code     String  @unique
  name     String
  phone    String  @unique
  email    String?
  province String?
  district String?
  ward     String?
  address  String?

  customerGroupId String? @map("customer_group_id")
  deliveryRouteId String? @map("delivery_route_id")
  saleId          String? @map("sale_id")

  priority        Priority       @default(MEDIUM)
  status          CustomerStatus @default(ACTIVE)
  defaultDiscount Decimal        @default(0) @map("default_discount") @db.Decimal(5, 2)
  debtLimit       Decimal        @default(0) @map("debt_limit") @db.Decimal(15, 0)
  debtTermDays    Int            @default(30) @map("debt_term_days")
  note            String?

  createdBy String?   @map("created_by")
  updatedBy String?   @map("updated_by")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  customerGroup CustomerGroup? @relation(fields: [customerGroupId], references: [id])
  deliveryRoute DeliveryRoute? @relation(fields: [deliveryRouteId], references: [id])
  sale          User?          @relation("CustomerSale", fields: [saleId], references: [id])
  createdByUser User?          @relation("CustomerCreatedBy", fields: [createdBy], references: [id])
  updatedByUser User?          @relation("CustomerUpdatedBy", fields: [updatedBy], references: [id])
  quotations    Quotation[]

  @@index([customerGroupId])
  @@index([deliveryRouteId])
  @@index([saleId])
  @@index([status])
  @@index([deletedAt])
  @@map("customers")
}

// ──────────────────────────────────────
// Quotation
// ──────────────────────────────────────

model Quotation {
  id           String          @id @default(cuid())
  code         String          @unique
  customerId   String          @map("customer_id")
  status       QuotationStatus @default(DRAFT)
  expiryDate   DateTime?       @map("expiry_date")
  note         String?
  salesOrderId String?         @unique @map("sales_order_id")

  createdBy String?  @map("created_by")
  updatedBy String?  @map("updated_by")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  customer   Customer            @relation(fields: [customerId], references: [id])
  salesOrder SalesOrder?         @relation(fields: [salesOrderId], references: [id])
  items      QuotationItem[]
  timeline   QuotationTimeline[]

  @@index([customerId])
  @@index([status])
  @@index([salesOrderId])
  @@index([expiryDate])
  @@map("quotations")
}

model QuotationItem {
  id          String  @id @default(cuid())
  quotationId String  @map("quotation_id")
  productId   String  @map("product_id")
  quantity    Decimal @db.Decimal(15, 4)

  pricingRuleVersionId         String? @map("pricing_rule_version_id")
  materialRequirementVersionId String? @map("material_requirement_version_id")

  systemPrice               Decimal @default(0) @map("system_price") @db.Decimal(15, 0)
  groupDiscount             Decimal @default(0) @map("group_discount") @db.Decimal(5, 2)
  additionalDiscountPercent Decimal @default(0) @map("additional_discount_percent") @db.Decimal(5, 2)
  additionalDiscountAmount  Decimal @default(0) @map("additional_discount_amount") @db.Decimal(15, 0)
  discountReason            String? @map("discount_reason")
  discountBy                String? @map("discount_by")
  finalPrice                Decimal @default(0) @map("final_price") @db.Decimal(15, 0)
  subtotal                  Decimal @default(0) @db.Decimal(15, 0)

  displayOrder Int      @default(0) @map("display_order")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  quotation  Quotation                @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  product    Product                  @relation(fields: [productId], references: [id])
  parameters QuotationItemParameter[]

  @@index([quotationId])
  @@index([productId])
  @@map("quotation_items")
}

model QuotationItemParameter {
  id              String   @id @default(cuid())
  quotationItemId String   @map("quotation_item_id")
  name            String
  label           String
  value           String
  unit            String?
  displayOrder    Int      @default(0) @map("display_order")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  quotationItem QuotationItem @relation(fields: [quotationItemId], references: [id], onDelete: Cascade)

  @@index([quotationItemId])
  @@map("quotation_item_parameters")
}

model QuotationTimeline {
  id          String                  @id @default(cuid())
  quotationId String                  @map("quotation_id")
  action      QuotationTimelineAction
  payload     Json?
  createdBy   String?                 @map("created_by")
  createdAt   DateTime                @default(now()) @map("created_at")

  quotation Quotation @relation(fields: [quotationId], references: [id])

  @@index([quotationId])
  @@index([quotationId, createdAt])
  @@map("quotation_timelines")
}

// ──────────────────────────────────────
// Sales Order (generated from Quotation.approve)
// ──────────────────────────────────────

model SalesOrder {
  id            String           @id @default(cuid())
  code          String           @unique
  quotationCode String           @map("quotation_code")
  customerId    String           @map("customer_id")
  customerName  String           @map("customer_name")
  customerPhone String           @map("customer_phone")
  status        SalesOrderStatus @default(IN_PRODUCTION)
  totalAmount   Decimal          @map("total_amount") @db.Decimal(15, 0)
  plannedCost   Decimal          @map("planned_cost") @db.Decimal(15, 0)
  plannedProfit Decimal          @map("planned_profit") @db.Decimal(15, 0)
  ownerName     String?          @map("owner_name")

  totalProductionOrders     Int @map("total_production_orders")
  completedProductionOrders Int @default(0) @map("completed_production_orders")

  expectedDeliveryDate DateTime? @map("expected_delivery_date")
  actualDeliveryDate   DateTime? @map("actual_delivery_date")

  paymentStatus PaymentStatus @default(UNPAID) @map("payment_status")

  note      String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  quotation        Quotation?
  items            SalesOrderItem[]
  productionOrders ProductionOrder[]
  timeline         SalesOrderTimeline[]
  receivable       Receivable?

  @@index([customerId])
  @@index([status])
  @@index([paymentStatus])
  // Dashboard (009-dashboard.md Task 06) — getDelayedOrders() lọc theo expectedDeliveryDate.
  @@index([expectedDeliveryDate])
  @@map("sales_orders")
}

model SalesOrderItem {
  id           String @id @default(cuid())
  salesOrderId String @map("sales_order_id")

  productId            String @map("product_id")
  productCode          String @map("product_code")
  productName          String @map("product_name")
  productionCenterId   String @map("production_center_id")
  productionCenterName String @map("production_center_name")

  pricingRuleVersionId      String? @map("pricing_rule_version_id")
  systemPrice               Decimal @map("system_price") @db.Decimal(15, 0)
  groupDiscount             Decimal @map("group_discount") @db.Decimal(5, 2)
  additionalDiscountPercent Decimal @default(0) @map("additional_discount_percent") @db.Decimal(5, 2)
  additionalDiscountAmount  Decimal @default(0) @map("additional_discount_amount") @db.Decimal(15, 0)
  finalPrice                Decimal @map("final_price") @db.Decimal(15, 0)
  quantity                  Decimal @db.Decimal(15, 4)
  subtotal                  Decimal @db.Decimal(15, 0)

  materialRequirementVersionId String? @map("material_requirement_version_id")
  plannedCost                  Decimal @default(0) @map("planned_cost") @db.Decimal(15, 0)

  displayOrder Int      @default(0) @map("display_order")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  salesOrder SalesOrder                @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)
  parameters SalesOrderItemParameter[]
  bom        OrderBOM?

  @@index([salesOrderId])
  @@map("sales_order_items")
}

model SalesOrderItemParameter {
  id               String   @id @default(cuid())
  salesOrderItemId String   @map("sales_order_item_id")
  name             String
  label            String
  value            String
  unit             String?
  displayOrder     Int      @default(0) @map("display_order")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  salesOrderItem SalesOrderItem @relation(fields: [salesOrderItemId], references: [id], onDelete: Cascade)

  @@index([salesOrderItemId])
  @@map("sales_order_item_parameters")
}

// ──────────────────────────────────────
// Order BOM (snapshot of Material Requirement)
// ──────────────────────────────────────

model OrderBOM {
  id                           String   @id @default(cuid())
  salesOrderId                 String   @map("sales_order_id")
  salesOrderItemId             String   @unique @map("sales_order_item_id")
  materialRequirementVersionId String   @map("material_requirement_version_id")
  plannedCost                  Decimal  @default(0) @map("planned_cost") @db.Decimal(15, 0)
  createdAt                    DateTime @default(now()) @map("created_at")
  updatedAt                    DateTime @updatedAt @map("updated_at")

  salesOrderItem SalesOrderItem @relation(fields: [salesOrderItemId], references: [id], onDelete: Cascade)
  items          OrderBOMItem[]

  @@index([salesOrderId])
  @@map("order_boms")
}

model OrderBOMItem {
  id           String    @id @default(cuid())
  orderBOMId   String    @map("order_bom_id")
  materialId   String    @map("material_id")
  materialCode String    @map("material_code")
  materialName String    @map("material_name")
  materialUnit String?   @map("material_unit")
  expression   String
  wastePercent Decimal   @default(0) @map("waste_percent") @db.Decimal(5, 2)
  roundType    RoundType @default(NONE) @map("round_type")
  roundValue   Decimal?  @map("round_value") @db.Decimal(15, 4)
  quantity     Decimal   @db.Decimal(15, 4)
  unitPrice    Decimal   @default(0) @map("unit_price") @db.Decimal(15, 2)
  lineTotal    Decimal   @default(0) @map("line_total") @db.Decimal(15, 0)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  orderBOM OrderBOM @relation(fields: [orderBOMId], references: [id], onDelete: Cascade)

  @@index([orderBOMId])
  @@map("order_bom_items")
}

// ──────────────────────────────────────
// Sales Order Timeline (audit log)
// ──────────────────────────────────────

model SalesOrderTimeline {
  id           String                      @id @default(cuid())
  salesOrderId String                      @map("sales_order_id")
  action       SalesOrderTimelineAction
  actorType    SalesOrderTimelineActorType @map("actor_type")
  payload      Json?
  createdBy    String?                     @map("created_by")
  createdAt    DateTime                    @default(now()) @map("created_at")

  salesOrder SalesOrder @relation(fields: [salesOrderId], references: [id])

  @@index([salesOrderId])
  @@index([salesOrderId, createdAt])
  @@map("sales_order_timelines")
}

// ──────────────────────────────────────
// Production Order
// ──────────────────────────────────────

model ProductionOrder {
  id                   String                @id @default(cuid())
  code                 String                @unique
  salesOrderId         String                @map("sales_order_id")
  productionCenterId   String                @map("production_center_id")
  productionCenterName String                @map("production_center_name")
  status               ProductionOrderStatus @default(PENDING)
  startedAt            DateTime?             @map("started_at")
  completedAt          DateTime?             @map("completed_at")
  createdAt            DateTime              @default(now()) @map("created_at")
  updatedAt            DateTime              @updatedAt @map("updated_at")

  salesOrder            SalesOrder                @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)
  items                 ProductionOrderItem[]
  timeline              ProductionOrderTimeline[]
  warehouseTransactions WarehouseTransaction[]

  @@index([salesOrderId])
  @@index([productionCenterId])
  @@index([status])
  @@map("production_orders")
}

model ProductionOrderItem {
  id                String   @id @default(cuid())
  productionOrderId String   @map("production_order_id")
  salesOrderItemId  String   @map("sales_order_item_id")
  productId         String   @map("product_id")
  productCode       String   @map("product_code")
  productName       String   @map("product_name")
  quantity          Decimal  @db.Decimal(15, 4)
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  productionOrder ProductionOrder @relation(fields: [productionOrderId], references: [id], onDelete: Cascade)

  @@index([productionOrderId])
  @@map("production_order_items")
}

// ──────────────────────────────────────
// Production Order Timeline (audit log)
// ──────────────────────────────────────

model ProductionOrderTimeline {
  id                String                           @id @default(cuid())
  productionOrderId String                           @map("production_order_id")
  action            ProductionOrderTimelineAction
  actorType         ProductionOrderTimelineActorType @map("actor_type")
  payload           Json?
  createdBy         String?                          @map("created_by")
  createdAt         DateTime                         @default(now()) @map("created_at")

  productionOrder ProductionOrder @relation(fields: [productionOrderId], references: [id])

  @@index([productionOrderId])
  @@index([productionOrderId, createdAt])
  @@map("production_order_timelines")
}

// ──────────────────────────────────────
// Warehouse (Material Receipt / Warehouse Transaction)
// ──────────────────────────────────────

model MaterialReceipt {
  id           String   @id @default(cuid())
  code         String   @unique
  materialId   String   @map("material_id")
  materialCode String   @map("material_code")
  materialName String   @map("material_name")
  unit         String
  quantity     Decimal  @db.Decimal(15, 4)
  supplierName String?  @map("supplier_name")
  note         String?
  createdBy    String?  @map("created_by")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  material    Material              @relation(fields: [materialId], references: [id])
  transaction WarehouseTransaction?

  @@index([materialId])
  @@map("material_receipts")
}

model WarehouseTransaction {
  id                String                   @id @default(cuid())
  direction         WarehouseDirection
  transactionType   WarehouseTransactionType @map("transaction_type")
  materialId        String                   @map("material_id")
  materialCode      String                   @map("material_code")
  materialName      String                   @map("material_name")
  unit              String
  quantity          Decimal                  @db.Decimal(15, 4)
  materialReceiptId String?                  @unique @map("material_receipt_id")
  productionOrderId String?                  @map("production_order_id")
  createdAt         DateTime                 @default(now()) @map("created_at")

  material        Material         @relation(fields: [materialId], references: [id])
  materialReceipt MaterialReceipt? @relation(fields: [materialReceiptId], references: [id])
  productionOrder ProductionOrder? @relation(fields: [productionOrderId], references: [id])

  // Idempotency (Task 03/07): một Production Order chỉ xuất kho đúng một lần cho mỗi vật tư —
  // enforce ở DB, không chỉ dựa vào validate status = PENDING ở tầng application.
  @@unique([productionOrderId, materialId])
  @@index([materialId])
  @@index([productionOrderId])
  // Dashboard (009-dashboard.md Task 07) — WarehouseService.getTopConsumedMaterials()
  // lọc theo direction/transactionType/createdAt trước khi GROUP BY materialId.
  @@index([transactionType, direction, createdAt])
  @@map("warehouse_transactions")
}

// ──────────────────────────────────────
// Debt (Accounts Receivable)
// ──────────────────────────────────────

model Receivable {
  id           String @id @default(cuid())
  salesOrderId String @unique @map("sales_order_id")
  // Redundant reference (copy ID bất biến, không phải Derived Data) — tránh
  // join qua SalesOrder cho các query tổng hợp theo khách hàng (Debt Monitoring).
  // Không dùng @relation, cùng convention với SalesOrder.customerId.
  customerId   String @map("customer_id")

  totalAmount     Decimal @map("total_amount") @db.Decimal(15, 0)
  paidAmount      Decimal @default(0) @map("paid_amount") @db.Decimal(15, 0)
  // Derived (totalAmount - paidAmount) nhưng được phép lưu — lý do hiệu năng đọc
  // (Dashboard/Debt Monitoring), cập nhật atomic trong PaymentService.create().
  // CHECK (remaining_amount >= 0) khai báo tay trong migration.sql.
  remainingAmount Decimal @map("remaining_amount") @db.Decimal(15, 0)

  // Credit Policy Snapshot — copy từ Customer.debtLimit/debtTermDays tại thời điểm tạo.
  debtLimitSnapshot    Decimal @map("debt_limit_snapshot") @db.Decimal(15, 0)
  debtTermDaysSnapshot Int     @map("debt_term_days_snapshot")

  // NULL lúc tạo, set = actualDeliveryDate + debtTermDaysSnapshot khi SalesOrder Delivered.
  dueDate DateTime? @map("due_date")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  salesOrder SalesOrder @relation(fields: [salesOrderId], references: [id])
  payments   Payment[]

  @@index([customerId])
  // Dashboard (009-dashboard.md Task 07) — overdue/risk/upcoming-due đều lọc theo dueDate.
  @@index([dueDate])
  @@map("receivables")
}

model Payment {
  id           String @id @default(cuid())
  code         String @unique
  // Redundant reference giữ cùng receivableId — lý do hiệu năng, tránh join
  // qua Receivable mỗi lần cần salesOrderId. Không dùng @relation (cùng
  // convention với các field redundant reference khác trong schema).
  salesOrderId String @map("sales_order_id")
  receivableId String @map("receivable_id")

  paymentDate     DateTime      @map("payment_date")
  amount          Decimal       @db.Decimal(15, 0)
  paymentMethod   PaymentMethod @map("payment_method")
  referenceNumber String?       @map("reference_number")
  note            String?
  createdBy       String?       @map("created_by")
  createdAt       DateTime      @default(now()) @map("created_at")

  receivable Receivable @relation(fields: [receivableId], references: [id])

  @@index([salesOrderId])
  @@index([receivableId])
  @@map("payments")
}

// ──────────────────────────────────────
// Settings
// ──────────────────────────────────────

// Singleton — chỉ đúng một bản ghi, seed sẵn ở migration/seed. Không có
// Create/Delete API (xem setting.md mục "Company Settings").
model Company {
  id             String   @id @default(cuid())
  companyName    String   @map("company_name")
  logo           String?
  address        String?
  phone          String?
  email          String?
  website        String?
  taxCode        String?  @map("tax_code")
  // Chỉ là nhãn hiển thị, không phải công tắc đa tiền tệ — xem setting.md.
  currency       String   @default("VND")
  currencySymbol String   @default("₫") @map("currency_symbol")
  timezone       String   @default("Asia/Ho_Chi_Minh")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("companies")
}

// Key-value dùng chung cho Dashboard/Notification/Document/Security/Backup
// Settings — chỉ giá trị Loại 1 (xem setting.md mục "Phân loại cấu hình").
// value/defaultValue lưu dạng String, FE/BE tự parse theo valueType.
model Setting {
  id           String           @id @default(cuid())
  module       String
  key          String
  value        String
  defaultValue String           @map("default_value")
  valueType    SettingValueType @map("value_type")
  description  String?
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")

  @@unique([module, key])
  @@index([module])
  @@map("settings")
}
